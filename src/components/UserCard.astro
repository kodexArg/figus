---
import type { MockUser } from '../data/types';
import ContactBadges from './ContactBadges.astro';
import { formatDistance } from '../lib/geo';

interface Props {
  user: MockUser;
  distanceKm?: number;
  highlight?: string;
}
const { user, distanceKm, highlight } = Astro.props;
const initials = user.name.split(' ').map((s) => s[0]).slice(0, 2).join('');
---

<article class="rounded-xl bg-slate-900/60 ring-1 ring-white/5 p-4 hover:ring-emerald-400/30 transition">
  <div class="flex items-start gap-3">
    <div class="h-10 w-10 rounded-full bg-gradient-to-br from-emerald-400 to-sky-500 text-slate-950 font-bold flex items-center justify-center">{initials}</div>
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 flex-wrap">
        <h3 class="font-semibold text-white truncate">{user.name}</h3>
        <span class="text-[10px] px-1.5 py-0.5 rounded bg-amber-400/20 text-amber-200">★ {user.rating.toFixed(1)}</span>
        <span class="text-[10px] text-slate-400">{user.trades} trades</span>
      </div>
      <p class="text-xs text-slate-400">{user.city} · <span class="text-slate-300">{formatDistance(distanceKm)}</span></p>
      {highlight && <p class="text-xs text-emerald-300 mt-1">{highlight}</p>}
    </div>
  </div>
  <div class="mt-3">
    <ContactBadges contacts={user.contacts} />
  </div>
</article>
