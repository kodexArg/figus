---
import type { Sticker } from '../data/types';
import { stickerImageUrl, emojiForType } from '../lib/images';
import { TYPE_LABELS } from '../data/stickers';

interface Props {
  sticker: Sticker;
  interactive?: boolean;
}

const { sticker, interactive = true } = Astro.props;

const rarityRing = {
  common: 'ring-slate-700/60',
  rare: 'ring-sky-400/50',
  legendary: 'ring-amber-400/70',
  foil: 'ring-fuchsia-400/60',
  parallel: 'ring-violet-400/60',
}[sticker.rarity];

const rarityGlow = {
  common: 'from-slate-700/30 to-slate-900/0',
  rare: 'from-sky-500/25 to-slate-900/0',
  legendary: 'from-amber-400/40 to-slate-900/0',
  foil: 'from-fuchsia-500/30 to-slate-900/0',
  parallel: 'from-violet-500/30 to-slate-900/0',
}[sticker.rarity];

const typeLabel = TYPE_LABELS[sticker.type];
const imgUrl = stickerImageUrl(sticker);
const emoji = imgUrl ? null : emojiForType(sticker.type);
const teamCode = sticker.team?.code ?? null;
---

<article
  class={`sticker-card group relative rounded-xl ring-1 ${rarityRing} bg-slate-900/60 overflow-hidden transition hover:scale-[1.02] hover:ring-emerald-400/60`}
  data-sticker-id={sticker.id}
  data-rarity={sticker.rarity}
  data-type={sticker.type}
  data-team={teamCode ?? ''}
>
  <div class={`absolute inset-0 bg-gradient-to-b ${rarityGlow} opacity-60`}></div>
  <div class="relative p-3 flex flex-col h-full min-h-[180px]">
    <div class="flex items-start justify-between gap-1">
      <span class="text-[10px] font-mono text-slate-400">{sticker.code}</span>
      <span class="text-[10px] uppercase tracking-wider text-slate-300/70">{typeLabel}</span>
    </div>

    <div class="flex-1 flex items-center justify-center my-2">
      {imgUrl ? (
        <img
          src={imgUrl}
          alt={sticker.label}
          loading="lazy"
          decoding="async"
          class={`h-20 w-20 object-contain ${sticker.type === 'team_emblem' || sticker.type === 'host_country' ? 'rounded-md ring-1 ring-white/10 bg-slate-800' : 'rounded-lg'}`}
        />
      ) : (
        <div class="h-20 w-20 rounded-lg bg-slate-800 card-hatch flex items-center justify-center text-3xl">
          {emoji}
        </div>
      )}
    </div>

    <div class="text-xs">
      <p class="font-semibold text-white truncate" title={sticker.label}>{sticker.label}</p>
      {sticker.team && <p class="text-slate-400 truncate">{sticker.team.name_es}</p>}
      {!sticker.team && sticker.parallel_set && <p class="text-slate-400 truncate">{sticker.parallel_set}</p>}
    </div>

    {sticker.is_foil && (
      <span class="absolute top-2 left-2 text-[9px] px-1 py-0.5 rounded bg-fuchsia-500/30 text-fuchsia-100 font-bold">FOIL</span>
    )}

    {interactive && (
      <div class="mt-2 flex items-center justify-between gap-2">
        <button
          type="button"
          data-action="dec"
          class="h-7 w-7 rounded-md bg-white/5 hover:bg-white/10 text-slate-300"
          aria-label="Quitar"
        >−</button>
        <span data-count class="text-sm font-mono text-slate-200 tabular-nums">0</span>
        <button
          type="button"
          data-action="inc"
          class="h-7 w-7 rounded-md bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-200"
          aria-label="Agregar"
        >+</button>
      </div>
    )}

    <div
      data-state-badge
      class="absolute top-2 right-2 px-1.5 py-0.5 rounded-full text-[9px] font-bold hidden"
    ></div>
  </div>
</article>
