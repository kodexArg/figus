---
interface Props {
  label: string;
  value: string | number;
  hint?: string;
  tone?: 'emerald' | 'sky' | 'amber' | 'rose' | 'slate';
}
const { label, value, hint, tone = 'slate' } = Astro.props;

const toneCls = {
  emerald: 'from-emerald-500/20 to-emerald-500/0 ring-emerald-400/30',
  sky: 'from-sky-500/20 to-sky-500/0 ring-sky-400/30',
  amber: 'from-amber-500/20 to-amber-500/0 ring-amber-400/30',
  rose: 'from-rose-500/20 to-rose-500/0 ring-rose-400/30',
  slate: 'from-slate-500/20 to-slate-500/0 ring-slate-400/20',
}[tone];
---

<div class={`rounded-2xl ring-1 bg-gradient-to-b ${toneCls} p-4`}>
  <p class="text-xs uppercase tracking-wider text-slate-400">{label}</p>
  <p class="mt-1 text-3xl font-black text-white tabular-nums">{value}</p>
  {hint && <p class="text-xs text-slate-400 mt-1">{hint}</p>}
</div>
