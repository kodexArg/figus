---
interface Props { path: string }
const { path } = Astro.props;

const links = [
  { href: '/', label: 'Inicio', icon: '⚽' },
  { href: '/album', label: 'Álbum', icon: '📖' },
  { href: '/repetidas', label: 'Repetidas', icon: '♻️' },
  { href: '/mercado', label: 'Mercado', icon: '🛒' },
  { href: '/sugerencias', label: 'Sugerencias', icon: '✨' },
  { href: '/mapa', label: 'Mapa', icon: '🗺️' },
  { href: '/perfil', label: 'Perfil', icon: '👤' },
];

const isActive = (href: string) => href === '/' ? path === '/' : path.startsWith(href);
---

<header class="sticky top-0 z-30 backdrop-blur bg-slate-950/70 border-b border-white/5">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 font-bold tracking-tight">
      <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-gradient-to-br from-emerald-400 to-sky-500 text-slate-950 text-base">F</span>
      <span class="text-white">Figus<span class="text-emerald-400">26</span></span>
    </a>
    <nav class="hidden md:flex items-center gap-1">
      {links.map((l) => (
        <a
          href={l.href}
          class={`px-3 py-1.5 rounded-full text-sm transition ${isActive(l.href) ? 'bg-emerald-500/20 text-emerald-200 ring-1 ring-emerald-400/40' : 'text-slate-300 hover:text-white hover:bg-white/5'}`}
        >
          <span class="mr-1">{l.icon}</span>{l.label}
        </a>
      ))}
    </nav>
    <button id="mobile-menu-btn" class="md:hidden text-slate-200" aria-label="Abrir menú">☰</button>
  </div>
  <div id="mobile-menu" class="md:hidden hidden border-t border-white/5 bg-slate-950/95">
    <div class="grid grid-cols-2 gap-1 p-2">
      {links.map((l) => (
        <a
          href={l.href}
          class={`px-3 py-2 rounded-lg text-sm ${isActive(l.href) ? 'bg-emerald-500/20 text-emerald-200' : 'text-slate-300 hover:bg-white/5'}`}
        >
          <span class="mr-1">{l.icon}</span>{l.label}
        </a>
      ))}
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
