---
import Layout from '../layouts/Layout.astro';
import StickerCard from '../components/StickerCard.astro';
import ProgressBar from '../components/ProgressBar.astro';
import { STICKERS, TOTAL_STICKERS } from '../data/stickers';
import { TEAMS } from '../data/teams';
---

<Layout title="Álbum — Figus 26">
  <section class="space-y-6">
    <header class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-white">Álbum Mundial 2026</h1>
        <p class="text-slate-400 text-sm">Tocá una figurita para sumar o restar. Las repetidas aparecen automáticamente en el mercado.</p>
      </div>
      <div class="flex items-center gap-2">
        <button id="seed-btn" class="text-xs px-3 py-1.5 rounded-md bg-white/5 hover:bg-white/10 text-slate-200">Cargar demo</button>
        <button id="reset-btn" class="text-xs px-3 py-1.5 rounded-md bg-rose-500/15 hover:bg-rose-500/25 text-rose-200">Vaciar</button>
      </div>
    </header>

    <ProgressBar value={0} max={TOTAL_STICKERS} label="Progreso del álbum" />

    <div class="flex flex-wrap items-center gap-2">
      <input
        type="search"
        id="filter-search"
        placeholder="Buscar (nombre, equipo, #)"
        class="flex-1 min-w-[200px] h-10 px-3 rounded-lg bg-slate-900/70 ring-1 ring-white/5 text-slate-200 placeholder:text-slate-500 focus:outline-none focus:ring-emerald-400/40"
      />
      <select id="filter-team" class="h-10 px-3 rounded-lg bg-slate-900/70 ring-1 ring-white/5 text-slate-200">
        <option value="">Todos los equipos</option>
        {TEAMS.map((t) => <option value={t.code}>{t.name_es}</option>)}
      </select>
      <select id="filter-type" class="h-10 px-3 rounded-lg bg-slate-900/70 ring-1 ring-white/5 text-slate-200">
        <option value="">Todos los tipos</option>
        <option value="team_emblem">Escudos</option>
        <option value="team_photo">Planteles</option>
        <option value="player">Jugadores</option>
        <option value="legend">Leyendas</option>
        <option value="mystery_player">Mystery Players</option>
        <option value="coca_cola_special">Coca-Cola LATAM</option>
        <option value="host_country">Anfitriones</option>
        <option value="mascot,official_ball,official_emblem,panini_logo,slogan">Especiales</option>
      </select>
      <select id="filter-state" class="h-10 px-3 rounded-lg bg-slate-900/70 ring-1 ring-white/5 text-slate-200">
        <option value="">Todas</option>
        <option value="missing">Faltantes</option>
        <option value="owned">Las que tengo</option>
        <option value="duplicate">Repetidas</option>
      </select>
    </div>

    <div id="sticker-grid" class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 xl:grid-cols-6 gap-3">
      {STICKERS.map((s) => <StickerCard sticker={s} />)}
    </div>
    <p id="empty-msg" class="hidden text-center text-slate-400 py-12">No hay figuritas con esos filtros.</p>
  </section>
</Layout>

<script>
  import { getCollection, increment, decrement, subscribe, seedDemoCollection, clearAll } from '../lib/store';

  const grid = document.getElementById('sticker-grid')!;
  const emptyMsg = document.getElementById('empty-msg')!;
  const cards = Array.from(grid.querySelectorAll<HTMLElement>('.sticker-card'));

  const search = document.getElementById('filter-search') as HTMLInputElement;
  const teamSel = document.getElementById('filter-team') as HTMLSelectElement;
  const typeSel = document.getElementById('filter-type') as HTMLSelectElement;
  const stateSel = document.getElementById('filter-state') as HTMLSelectElement;
  const progress = document.querySelector<HTMLElement>('[data-progress]')!;
  const progressBar = progress.querySelector<HTMLElement>('[data-progress-bar]')!;
  const progressValueEl = progress.querySelector<HTMLElement>('[data-progress-value]')!;
  const progressPctEl = progress.querySelector<HTMLElement>('[data-progress-pct]')!;
  const maxStickers = Number(progress.dataset.max);

  function render() {
    const collection = getCollection();
    let owned = 0;
    let totalDup = 0;

    for (const card of cards) {
      const id = card.dataset.stickerId!;
      const count = collection[id] ?? 0;
      const countEl = card.querySelector<HTMLElement>('[data-count]')!;
      const badge = card.querySelector<HTMLElement>('[data-state-badge]')!;
      countEl.textContent = String(count);

      if (count > 0) owned++;
      if (count > 1) totalDup += count - 1;

      // visual state
      card.classList.remove('opacity-50', 'ring-emerald-400/60', 'ring-amber-400/60');
      badge.classList.add('hidden');
      if (count === 0) {
        card.classList.add('opacity-50');
      } else if (count === 1) {
        card.classList.add('ring-emerald-400/60');
        badge.textContent = '✓';
        badge.className = 'absolute top-2 right-2 px-1.5 py-0.5 rounded-full text-[9px] font-bold bg-emerald-500/30 text-emerald-100';
      } else {
        card.classList.add('ring-amber-400/60');
        badge.textContent = `×${count}`;
        badge.className = 'absolute top-2 right-2 px-1.5 py-0.5 rounded-full text-[9px] font-bold bg-amber-500/30 text-amber-100';
      }
    }

    const pct = maxStickers > 0 ? Math.round((owned / maxStickers) * 100) : 0;
    progressBar.style.width = `${pct}%`;
    progressValueEl.textContent = String(owned);
    progressPctEl.textContent = String(pct);

    applyFilters();
  }

  function applyFilters() {
    const collection = getCollection();
    const q = search.value.trim().toLowerCase();
    const team = teamSel.value;
    const type = typeSel.value;
    const state = stateSel.value;

    let visible = 0;
    for (const card of cards) {
      const id = card.dataset.stickerId!;
      const matchTeam = !team || card.dataset.team === team;
      const matchType = !type || type.split(',').includes(card.dataset.type ?? '');
      const count = collection[id] ?? 0;
      const matchState =
        !state ||
        (state === 'missing' && count === 0) ||
        (state === 'owned' && count >= 1) ||
        (state === 'duplicate' && count > 1);
      const text = card.textContent?.toLowerCase() ?? '';
      const matchQuery = !q || text.includes(q) || id.toLowerCase().includes(q);

      const show = matchTeam && matchType && matchState && matchQuery;
      card.classList.toggle('hidden', !show);
      if (show) visible++;
    }
    emptyMsg.classList.toggle('hidden', visible > 0);
  }

  grid.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    const btn = target.closest<HTMLButtonElement>('button[data-action]');
    if (!btn) return;
    const card = btn.closest<HTMLElement>('.sticker-card')!;
    const id = card.dataset.stickerId!;
    if (btn.dataset.action === 'inc') increment(id);
    else decrement(id);
  });

  [search, teamSel, typeSel, stateSel].forEach((el) => el.addEventListener('input', applyFilters));

  document.getElementById('seed-btn')!.addEventListener('click', () => {
    if (confirm('Cargar colección de demo? Reemplaza tu progreso actual.')) seedDemoCollection();
  });
  document.getElementById('reset-btn')!.addEventListener('click', () => {
    if (confirm('Vaciar toda la colección?')) clearAll();
  });

  subscribe(render);
  render();
</script>
