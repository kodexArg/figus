---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Perfil — Figus 26">
  <section class="space-y-6 max-w-2xl">
    <header>
      <h1 class="text-2xl font-bold text-white">Mi perfil</h1>
      <p class="text-slate-400 text-sm">Definí cómo te contactan y dónde estás para que el mapa y las sugerencias funcionen mejor.</p>
    </header>

    <form id="profile-form" class="space-y-4 rounded-2xl bg-slate-900/60 ring-1 ring-white/5 p-5">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
        <label class="block">
          <span class="text-xs uppercase tracking-wider text-slate-400">Nombre</span>
          <input name="name" type="text" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="Tu nombre" />
        </label>
        <label class="block">
          <span class="text-xs uppercase tracking-wider text-slate-400">Ciudad</span>
          <input name="city" type="text" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="CABA, Rosario, etc." />
        </label>
      </div>

      <fieldset class="space-y-2">
        <legend class="text-xs uppercase tracking-wider text-slate-400">Ubicación</legend>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <label class="block">
            <span class="text-[10px] text-slate-500">Latitud</span>
            <input name="lat" type="number" step="0.000001" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="-34.60" />
          </label>
          <label class="block">
            <span class="text-[10px] text-slate-500">Longitud</span>
            <input name="lng" type="number" step="0.000001" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="-58.38" />
          </label>
          <button type="button" id="geo-btn" class="sm:self-end h-10 px-3 rounded-lg bg-emerald-500/20 hover:bg-emerald-500/30 text-emerald-200 text-sm">Usar mi ubicación actual</button>
        </div>
        <p id="geo-msg" class="text-xs text-slate-500"></p>
      </fieldset>

      <fieldset class="space-y-2">
        <legend class="text-xs uppercase tracking-wider text-slate-400">Contactos (al menos uno)</legend>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          <label class="block">
            <span class="text-[10px] text-slate-500">WhatsApp (con +código país)</span>
            <input name="whatsapp" type="tel" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="+5491133334444" />
          </label>
          <label class="block">
            <span class="text-[10px] text-slate-500">Instagram</span>
            <input name="instagram" type="text" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="@usuario" />
          </label>
          <label class="block">
            <span class="text-[10px] text-slate-500">Telegram</span>
            <input name="telegram" type="text" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="@usuario" />
          </label>
          <label class="block">
            <span class="text-[10px] text-slate-500">Email</span>
            <input name="email" type="email" class="mt-1 w-full h-10 px-3 rounded-lg bg-slate-950/70 ring-1 ring-white/5 text-slate-200" placeholder="tu@mail.com" />
          </label>
        </div>
      </fieldset>

      <div class="flex items-center justify-between gap-2 pt-2">
        <button type="submit" class="h-10 px-4 rounded-lg bg-emerald-500/30 hover:bg-emerald-500/40 text-emerald-100 font-semibold">Guardar</button>
        <span id="save-msg" class="text-xs text-emerald-300 opacity-0 transition">Guardado ✓</span>
      </div>
    </form>

    <div class="rounded-2xl bg-slate-900/40 ring-1 ring-rose-400/20 p-5">
      <h2 class="text-rose-300 font-semibold">Zona peligrosa</h2>
      <p class="text-sm text-slate-400 mt-1">Borrá tu colección y perfil para empezar de cero.</p>
      <button id="clear-all" class="mt-3 h-9 px-3 rounded-lg bg-rose-500/20 hover:bg-rose-500/30 text-rose-200 text-sm">Borrar todo</button>
    </div>
  </section>
</Layout>

<script>
  import { getProfile, setProfile, clearAll } from '../lib/store';

  const form = document.getElementById('profile-form') as HTMLFormElement;
  const saveMsg = document.getElementById('save-msg')!;
  const geoMsg = document.getElementById('geo-msg')!;

  function load() {
    const p = getProfile();
    (form.elements.namedItem('name') as HTMLInputElement).value = p.name ?? '';
    (form.elements.namedItem('city') as HTMLInputElement).value = p.city ?? '';
    (form.elements.namedItem('lat') as HTMLInputElement).value = p.lat != null ? String(p.lat) : '';
    (form.elements.namedItem('lng') as HTMLInputElement).value = p.lng != null ? String(p.lng) : '';
    (form.elements.namedItem('whatsapp') as HTMLInputElement).value = p.contacts.whatsapp ?? '';
    (form.elements.namedItem('instagram') as HTMLInputElement).value = p.contacts.instagram ?? '';
    (form.elements.namedItem('telegram') as HTMLInputElement).value = p.contacts.telegram ?? '';
    (form.elements.namedItem('email') as HTMLInputElement).value = p.contacts.email ?? '';
  }

  form.addEventListener('submit', (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const latRaw = fd.get('lat') as string;
    const lngRaw = fd.get('lng') as string;
    setProfile({
      name: (fd.get('name') as string)?.trim() || '',
      city: (fd.get('city') as string)?.trim() || '',
      lat: latRaw ? Number(latRaw) : null,
      lng: lngRaw ? Number(lngRaw) : null,
      contacts: {
        whatsapp: (fd.get('whatsapp') as string)?.trim() || undefined,
        instagram: (fd.get('instagram') as string)?.trim() || undefined,
        telegram: (fd.get('telegram') as string)?.trim() || undefined,
        email: (fd.get('email') as string)?.trim() || undefined,
      },
    });
    saveMsg.style.opacity = '1';
    setTimeout(() => { saveMsg.style.opacity = '0'; }, 1500);
  });

  document.getElementById('geo-btn')!.addEventListener('click', () => {
    if (!navigator.geolocation) {
      geoMsg.textContent = 'Tu navegador no soporta geolocalización.';
      return;
    }
    geoMsg.textContent = 'Pidiendo permiso…';
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        (form.elements.namedItem('lat') as HTMLInputElement).value = pos.coords.latitude.toFixed(6);
        (form.elements.namedItem('lng') as HTMLInputElement).value = pos.coords.longitude.toFixed(6);
        geoMsg.textContent = 'Ubicación obtenida ✓';
      },
      (err) => { geoMsg.textContent = `No se pudo obtener: ${err.message}`; },
      { enableHighAccuracy: false, timeout: 8000 },
    );
  });

  document.getElementById('clear-all')!.addEventListener('click', () => {
    if (confirm('¿Borrar colección y perfil?')) {
      clearAll();
      load();
    }
  });

  load();
</script>
