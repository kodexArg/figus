---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mapa — Figus 26">
  <section class="space-y-4">
    <header class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-white">Mapa de coleccionistas</h1>
        <p class="text-slate-400 text-sm">Cada pin es un colee con figuritas repetidas. Tocá uno para ver contactos.</p>
      </div>
      <div class="flex items-center gap-2 text-xs text-slate-300">
        <label class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-emerald-400 ring-2 ring-emerald-300/50"></span>Vos</label>
        <label class="flex items-center gap-1.5"><span class="h-2.5 w-2.5 rounded-full bg-sky-400"></span>Colees</label>
      </div>
    </header>

    <div id="map" class="h-[70vh] rounded-2xl ring-1 ring-white/10 overflow-hidden bg-slate-900"></div>
  </section>
</Layout>

<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />

<script>
  import { getProfile, subscribe } from '../lib/store';
  import { USERS } from '../data/users';

  type LType = typeof import('leaflet');
  let L: LType;
  let map: any;
  let userMarkers: any[] = [];
  let meMarker: any = null;

  async function ensureLeaflet() {
    if (L) return L;
    L = await import('leaflet');
    return L;
  }

  async function init() {
    await ensureLeaflet();
    const profile = getProfile();
    const center: [number, number] = profile.lat != null && profile.lng != null
      ? [profile.lat, profile.lng]
      : [-34.6037, -58.3816];

    map = L.map('map', { zoomControl: true }).setView(center, 5);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
      attribution: '&copy; OpenStreetMap',
      maxZoom: 19,
    }).addTo(map);

    drawUsers();
    drawMe();
  }

  function userIcon() {
    return L.divIcon({
      className: 'figus-pin',
      html: '<div style="width:14px;height:14px;border-radius:50%;background:#38bdf8;box-shadow:0 0 0 4px rgba(56,189,248,.25);border:2px solid #0a0f1c"></div>',
      iconSize: [14, 14],
      iconAnchor: [7, 7],
    });
  }
  function meIcon() {
    return L.divIcon({
      className: 'figus-pin-me',
      html: '<div style="width:16px;height:16px;border-radius:50%;background:#34d399;box-shadow:0 0 0 6px rgba(52,211,153,.3);border:2px solid #0a0f1c"></div>',
      iconSize: [16, 16],
      iconAnchor: [8, 8],
    });
  }

  function drawUsers() {
    userMarkers.forEach((m) => map.removeLayer(m));
    userMarkers = [];
    for (const u of USERS) {
      const duplicates = Object.values(u.inventory).filter((n) => n > 1).reduce((a, n) => a + (n - 1), 0);
      const marker = L.marker([u.lat, u.lng], { icon: userIcon() }).addTo(map);
      const wa = u.contacts.whatsapp ? `<a href="https://wa.me/${u.contacts.whatsapp.replace(/[^0-9]/g,'')}" target="_blank" style="color:#34d399">WhatsApp</a>` : '';
      const ig = u.contacts.instagram ? `<a href="https://instagram.com/${u.contacts.instagram.replace(/^@/,'')}" target="_blank" style="color:#e879f9;margin-left:6px">Instagram</a>` : '';
      const tg = u.contacts.telegram ? `<a href="https://t.me/${u.contacts.telegram.replace(/^@/,'')}" target="_blank" style="color:#38bdf8;margin-left:6px">Telegram</a>` : '';
      marker.bindPopup(`
        <div style="font-family:system-ui;min-width:180px">
          <strong>${u.name}</strong><br>
          <span style="color:#64748b;font-size:12px">${u.city} · ★ ${u.rating.toFixed(1)}</span>
          <div style="margin-top:6px;font-size:12px">${duplicates} repetidas · ${u.wants.length} faltan</div>
          <div style="margin-top:6px;font-size:12px">${wa}${ig}${tg}</div>
        </div>
      `);
      userMarkers.push(marker);
    }
  }

  function drawMe() {
    const profile = getProfile();
    if (meMarker) {
      map.removeLayer(meMarker);
      meMarker = null;
    }
    if (profile.lat != null && profile.lng != null) {
      meMarker = L.marker([profile.lat, profile.lng], { icon: meIcon() })
        .bindPopup(`<strong>${profile.name || 'Vos'}</strong><br><span style="color:#64748b">${profile.city || '—'}</span>`)
        .addTo(map);
    }
  }

  document.addEventListener('DOMContentLoaded', init);
  subscribe(() => {
    if (map) drawMe();
  });
</script>
